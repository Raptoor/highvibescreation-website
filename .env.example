# Copiază la .env lângă compose.yaml sau setează aceleași chei în Coolify → Environment
# OBLIGATORIU pentru producție:
ALLOWED_ORIGINS=https://highvibescreation.com,https://www.highvibescreation.com

# SMTP: pe același server cu Coolify (Postfix ascultă pe host) → host.docker.internal
SMTP_HOST=host.docker.internal
SMTP_PORT=587
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

MAIL_FROM=website@highvibescreation.com
MAIL_TO=office@highvibescreation.com

MAIL_API_PORT=3000
