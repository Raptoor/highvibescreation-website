# URL-urile site-ului (origini permise CORS), separate prin virgulă
ALLOWED_ORIGINS=https://highvibescreation.com,https://www.highvibescreation.com

# SMTP (Postfix pe același host sau alt server)
SMTP_HOST=127.0.0.1
SMTP_PORT=587
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

MAIL_FROM=website@highvibescreation.com
MAIL_TO=office@highvibescreation.com

# Limită: max cereri per fereastră (implicit 60s), per IP, per endpoint
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_CONTACT_MAX=1
RATE_LIMIT_NEWSLETTER_MAX=1

PORT=3000
